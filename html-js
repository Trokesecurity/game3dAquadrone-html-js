import * as THREE from 'https://unpkg.com/three@0.165.0/build/three.module.js';

const canvas = document.getElementById('game');
const hudScore = document.getElementById('score');
const hudTimer = document.getElementById('timer');
const hudSpeed = document.getElementById('speed');
const centerMessage = document.getElementById('message');

const scene = new THREE.Scene();
scene.fog = new THREE.FogExp2(0x04334a, 0.02);

const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 700);

const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setClearColor(0x04263b);

const hemi = new THREE.HemisphereLight(0x78f7ff, 0x02131f, 1.2);
scene.add(hemi);

const key = new THREE.DirectionalLight(0x8ddfff, 1.1);
key.position.set(15, 18, 8);
scene.add(key);

const floorGeometry = new THREE.PlaneGeometry(500, 500, 64, 64);
const floorMaterial = new THREE.MeshStandardMaterial({ color: 0x0a3044, roughness: 0.95, metalness: 0.05 });
const floor = new THREE.Mesh(floorGeometry, floorMaterial);
floor.rotation.x = -Math.PI / 2;
floor.position.y = -12;
scene.add(floor);

const drone = buildDrone();
drone.position.set(0, -2, 0);
scene.add(drone);

const waterParticles = makeParticles(1200);
scene.add(waterParticles);

spawnReefs(180);

const cells = [];
spawnCells(10);

let score = 0;
let timeLeft = 120;
let ended = false;

const velocity = new THREE.Vector3();
const direction = new THREE.Vector3();
const worldUp = new THREE.Vector3(0, 1, 0);

const input = {
  forward: 0,
  strafe: 0,
  vertical: 0,
  boost: false,
  yaw: 0,
  pitch: 0,
  pointerLocked: false,
};

const params = {
  accel: 24,
  damping: 2.2,
  maxSpeed: 18,
  boostMultiplier: 1.9,
  verticalAccel: 12,
  mouseSensitivity: 0.0023,
  pitchLimit: Math.PI / 2.3,
};

let yaw = 0;
let pitch = 0;

canvas.addEventListener('click', () => {
  if (!input.pointerLocked && !ended) {
    canvas.requestPointerLock();
  }
});

document.addEventListener('pointerlockchange', () => {
  input.pointerLocked = document.pointerLockElement === canvas;
  centerMessage.textContent = input.pointerLocked
    ? 'Colete 10 células antes do tempo acabar!'
    : 'Clique para capturar o mouse e continuar';
});

document.addEventListener('mousemove', (event) => {
  if (!input.pointerLocked || ended) {
    return;
  }

  yaw -= event.movementX * params.mouseSensitivity;
  pitch -= event.movementY * params.mouseSensitivity;
  pitch = THREE.MathUtils.clamp(pitch, -params.pitchLimit, params.pitchLimit);
});

const keyMap = new Map([
  ['KeyW', ['forward', 1]],
  ['KeyS', ['forward', -1]],
  ['KeyD', ['strafe', 1]],
  ['KeyA', ['strafe', -1]],
  ['Space', ['vertical', 1]],
  ['ControlLeft', ['vertical', -1]],
  ['ControlRight', ['vertical', -1]],
]);

document.addEventListener('keydown', (event) => {
  if (event.code === 'ShiftLeft' || event.code === 'ShiftRight') {
    input.boost = true;
  }

  if (event.code === 'KeyR') {
    resetGame();
    return;
  }

  const mapping = keyMap.get(event.code);
  if (!mapping) {
    return;
  }

  input[mapping[0]] = mapping[1];
});

document.addEventListener('keyup', (event) => {
  if (event.code === 'ShiftLeft' || event.code === 'ShiftRight') {
    input.boost = false;
  }

  const mapping = keyMap.get(event.code);
  if (!mapping) {
    return;
  }

  if (input[mapping[0]] === mapping[1]) {
    input[mapping[0]] = 0;
  }
});

window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});

const clock = new THREE.Clock();
animate();

function animate() {
  requestAnimationFrame(animate);

  const dt = Math.min(clock.getDelta(), 0.033);

  if (!ended && input.pointerLocked) {
    updateDrone(dt);
    updateCells(dt);
    updateTimer(dt);
    updateParticles(dt);
  }

  updateCamera(dt);
  updateHUD();
  renderer.render(scene, camera);
}

function updateDrone(dt) {
  const boost = input.boost ? params.boostMultiplier : 1;
  const localForward = new THREE.Vector3(0, 0, -1).applyAxisAngle(worldUp, yaw);
  const localRight = new THREE.Vector3(1, 0, 0).applyAxisAngle(worldUp, yaw);

  direction
    .set(0, 0, 0)
    .addScaledVector(localForward, input.forward)
    .addScaledVector(localRight, input.strafe)
    .normalize();

  if (Number.isFinite(direction.x)) {
    velocity.addScaledVector(direction, params.accel * boost * dt);
  }

  velocity.y += input.vertical * params.verticalAccel * dt;
  velocity.multiplyScalar(Math.exp(-params.damping * dt));

  const max = params.maxSpeed * boost;
  if (velocity.length() > max) {
    velocity.setLength(max);
  }

  drone.position.addScaledVector(velocity, dt);

  drone.position.x = THREE.MathUtils.clamp(drone.position.x, -150, 150);
  drone.position.y = THREE.MathUtils.clamp(drone.position.y, -11, 26);
  drone.position.z = THREE.MathUtils.clamp(drone.position.z, -150, 150);

  const moveYaw = velocity.lengthSq() > 0.0001 ? Math.atan2(-velocity.x, -velocity.z) : yaw;
  const visualYaw = THREE.MathUtils.lerpAngle(drone.rotation.y, moveYaw, 0.08);
  drone.rotation.y = visualYaw;
  drone.rotation.x = THREE.MathUtils.lerp(drone.rotation.x, -velocity.y * 0.06, 0.08);
  drone.rotation.z = THREE.MathUtils.lerp(drone.rotation.z, input.strafe * -0.35, 0.09);
}

function updateCamera(dt) {
  const cameraOffset = new THREE.Vector3(0, 2, 7)
    .applyAxisAngle(new THREE.Vector3(1, 0, 0), -pitch * 0.2)
    .applyAxisAngle(worldUp, yaw);

  const targetPosition = drone.position.clone().add(cameraOffset);
  camera.position.lerp(targetPosition, 1 - Math.exp(-5.5 * dt));

  const lookTarget = drone.position.clone().addScaledVector(new THREE.Vector3(0, 0, -1).applyAxisAngle(worldUp, yaw), 6);
  lookTarget.y += THREE.MathUtils.clamp(pitch * 2.2, -2.5, 2.5);
  camera.lookAt(lookTarget);
}

function updateCells(dt) {
  for (const cell of cells) {
    if (!cell.visible) {
      continue;
    }

    cell.rotation.y += dt * 1.9;
    cell.position.y += Math.sin(clock.elapsedTime * 2 + cell.userData.phase) * dt * 0.45;

    const distance = cell.position.distanceTo(drone.position);
    if (distance < 1.6) {
      cell.visible = false;
      score += 1;
      if (score >= cells.length) {
        endGame(true);
      }
    }
  }
}

function updateTimer(dt) {
  timeLeft = Math.max(0, timeLeft - dt);
  if (timeLeft <= 0) {
    endGame(false);
  }
}

function updateParticles(dt) {
  const positions = waterParticles.geometry.attributes.position;
  for (let i = 0; i < positions.count; i++) {
    const y = positions.getY(i) + dt * 1.4;
    positions.setY(i, y > 28 ? -14 : y);
  }

  positions.needsUpdate = true;
  waterParticles.rotation.y += dt * 0.012;
}

function updateHUD() {
  hudScore.textContent = String(score);
  hudTimer.textContent = String(Math.ceil(timeLeft));
  hudSpeed.textContent = velocity.length().toFixed(1);
}

function endGame(victory) {
  if (ended) {
    return;
  }

  ended = true;
  input.pointerLocked = false;
  document.exitPointerLock();

  centerMessage.innerHTML = victory
    ? '<strong>Missão concluída!</strong><br/>Você coletou todas as células. Pressione R para reiniciar.'
    : '<strong>Tempo esgotado!</strong><br/>Pressione R para tentar novamente.';
}

function resetGame() {
  score = 0;
  timeLeft = 120;
  ended = false;
  yaw = 0;
  pitch = 0;

  velocity.set(0, 0, 0);
  drone.position.set(0, -2, 0);
  drone.rotation.set(0, 0, 0);

  for (const cell of cells) {
    cell.visible = true;
  }

  centerMessage.textContent = 'Clique para iniciar • WASD + Mouse • Space/Ctrl para subir/descer • Shift para boost';
}

function buildDrone() {
  const group = new THREE.Group();

  const body = new THREE.Mesh(
    new THREE.SphereGeometry(1.15, 28, 20),
    new THREE.MeshStandardMaterial({
      color: 0x22d0da,
      emissive: 0x0d93aa,
      emissiveIntensity: 0.45,
      roughness: 0.22,
      metalness: 0.72,
    }),
  );
  body.scale.set(1.3, 0.55, 1.7);
  group.add(body);

  const wingMaterial = new THREE.MeshStandardMaterial({
    color: 0x1e627a,
    emissive: 0x21e8ff,
    emissiveIntensity: 0.3,
    roughness: 0.32,
    metalness: 0.45,
  });

  const leftWing = new THREE.Mesh(new THREE.CapsuleGeometry(0.36, 3.2, 6, 18), wingMaterial);
  leftWing.rotation.z = Math.PI / 2.2;
  leftWing.rotation.y = Math.PI / 2;
  leftWing.position.set(-1.65, 0.05, -0.2);
  group.add(leftWing);

  const rightWing = leftWing.clone();
  rightWing.position.x = 1.65;
  rightWing.rotation.z = -Math.PI / 2.2;
  group.add(rightWing);

  const glass = new THREE.Mesh(
    new THREE.SphereGeometry(0.58, 20, 16),
    new THREE.MeshPhysicalMaterial({ color: 0x021018, transmission: 0.86, roughness: 0.05, thickness: 0.45 }),
  );
  glass.position.set(0, 0.06, 1.25);
  glass.scale.set(1.6, 0.6, 0.8);
  group.add(glass);

  const lightMat = new THREE.MeshBasicMaterial({ color: 0x5ffff7 });
  const lamp1 = new THREE.Mesh(new THREE.SphereGeometry(0.16, 12, 12), lightMat);
  lamp1.position.set(-1.1, -0.15, 1.35);
  const lamp2 = lamp1.clone();
  lamp2.position.x = 1.1;
  group.add(lamp1, lamp2);

  return group;
}

function spawnCells(total) {
  for (let i = 0; i < total; i++) {
    const cell = new THREE.Mesh(
      new THREE.OctahedronGeometry(0.55, 0),
      new THREE.MeshStandardMaterial({
        color: 0x63f5ff,
        emissive: 0x31e8ff,
        emissiveIntensity: 0.75,
        roughness: 0.2,
        metalness: 0.1,
      }),
    );

    const phase = Math.random() * Math.PI * 2;
    cell.userData.phase = phase;
    cell.position.set(rand(-125, 125), rand(-8, 20), rand(-125, 125));
    scene.add(cell);
    cells.push(cell);
  }
}

function spawnReefs(total) {
  const reefMat = new THREE.MeshStandardMaterial({
    color: 0x0a4f63,
    roughness: 1,
    metalness: 0,
  });

  for (let i = 0; i < total; i++) {
    const reef = new THREE.Mesh(
      new THREE.CylinderGeometry(rand(0.2, 1.1), rand(0.6, 2.3), rand(0.8, 6.5), 6),
      reefMat,
    );

    reef.position.set(rand(-220, 220), -11 + reef.geometry.parameters.height * 0.5, rand(-220, 220));
    reef.rotation.y = Math.random() * Math.PI;
    reef.scale.y = rand(0.8, 1.6);
    scene.add(reef);
  }
}

function makeParticles(total) {
  const geometry = new THREE.BufferGeometry();
  const positions = new Float32Array(total * 3);

  for (let i = 0; i < total; i++) {
    positions[i * 3] = rand(-180, 180);
    positions[i * 3 + 1] = rand(-14, 28);
    positions[i * 3 + 2] = rand(-180, 180);
  }

  geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));

  const material = new THREE.PointsMaterial({
    color: 0x84faff,
    size: 0.11,
    transparent: true,
    opacity: 0.45,
    depthWrite: false,
  });

  return new THREE.Points(geometry, material);
}

function rand(min, max) {
  return Math.random() * (max - min) + min;
}
